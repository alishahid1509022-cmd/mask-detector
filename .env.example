# Copy this file to .env and adjust values for your machine.
# .env is git-ignored - never commit real secrets here.

# Index of the webcam to use (0 is usually the built-in camera)
CAMERA_INDEX=0

# Target camera/display frame rate (best-effort; actual FPS depends on your
# camera/hardware, but the display loop is paced to not exceed this)
TARGET_FPS=30

# Minimum detection confidence (0.0 - 1.0) required to show/act on a detection
CONFIDENCE_THRESHOLD=0.5

# Path to the YOLOv8 mask-detection weights file. Auto-downloaded here if
# missing - see MODEL_URL / MODEL_HF_REPO below.
MODEL_PATH=models/yolov8_mask.pt

# If set, weights are downloaded directly from this URL (a Roboflow Universe
# export, GitHub Release asset, etc.). Leave unset to use the default
# Hugging Face Hub repo below instead.
# MODEL_URL=

# Default automatic-download source when MODEL_URL is not set. Override if
# you fine-tune your own weights and publish them to a different repo.
MODEL_HF_REPO=krishnamishra8848/Face_Mask_Detection
MODEL_HF_FILENAME=best.pt

# "auto" picks the fastest available device (CUDA GPU > Apple Silicon MPS >
# CPU) for real-time inference. Force a specific one with "cpu"/"cuda"/"mps".
DEVICE=auto

# Resolution YOLOv8 resizes frames to internally before inference. Lower
# values run faster but may miss small/far-away faces.
INFERENCE_IMG_SIZE=640

# Seconds to wait between repeated "no mask" voice alerts (the cooldown
# timer that prevents spamming a new alert every single frame)
ALERT_COOLDOWN_SECONDS=5

# Exact phrase spoken/shown on a no-mask alert
ALERT_MESSAGE=Please wear your face mask.

# Which text-to-speech backend to try first: "pyttsx3" (offline, default) or
# "gtts" (online). If this one fails to initialize (e.g. pyttsx3 with no OS
# speech driver installed), the other is tried automatically as a fallback.
TTS_ENGINE=pyttsx3

# Folder where automatic no-mask screenshots are saved (created if missing)
SCREENSHOTS_DIR=Screenshots

# Seconds to wait between automatic no-mask screenshots (prevents saving a
# near-duplicate file on every single frame during a sustained no-mask streak)
SCREENSHOT_COOLDOWN_SECONDS=5

# Seconds without a successful camera read before a mid-session camera is
# treated as disconnected (unplugged, permission revoked, driver crashed)
CAMERA_DISCONNECT_TIMEOUT_SECONDS=5

# Consecutive frame-read/detection failures tolerated before the detection
# loop gives up and stops itself with a friendly error
MAX_CONSECUTIVE_FRAME_ERRORS=10

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
